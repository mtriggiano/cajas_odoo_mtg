<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_treasury_cash_move_voucher_a6" model="report.paperformat">
        <field name="name">Comprobante Caja A6 Horizontal</field>
        <field name="default" eval="False"/>
        <field name="format">A6</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">5</field>
        <field name="margin_bottom">5</field>
        <field name="margin_left">6</field>
        <field name="margin_right">6</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
    </record>

    <!-- ============================================================ -->
    <!-- Movement Voucher Report -->
    <!-- ============================================================ -->
    <record id="action_report_move_voucher" model="ir.actions.report">
        <field name="name">Comprobante de Movimiento</field>
        <field name="model">treasury.cash.move</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">treasury_cash.report_move_voucher</field>
        <field name="report_file">treasury_cash.report_move_voucher</field>
        <field name="binding_model_id" ref="model_treasury_cash_move"/>
        <field name="binding_type">report</field>
    </record>

    <record id="action_report_move_voucher_pdf" model="ir.actions.report">
        <field name="name">Comprobante de Movimiento (PDF)</field>
        <field name="model">treasury.cash.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">treasury_cash.report_move_voucher</field>
        <field name="report_file">treasury_cash.report_move_voucher</field>
        <field name="paperformat_id" ref="treasury_cash.paperformat_treasury_cash_move_voucher_a6"/>
    </record>

    <!-- ============================================================ -->
    <!-- Session Closing Report -->
    <!-- ============================================================ -->
    <record id="action_report_session_close" model="ir.actions.report">
        <field name="name">Reporte de Cierre de Sesión</field>
        <field name="model">treasury.cash.session</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">treasury_cash.report_session_close</field>
        <field name="report_file">treasury_cash.report_session_close</field>
        <field name="binding_model_id" ref="model_treasury_cash_session"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
