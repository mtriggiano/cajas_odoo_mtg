<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_move_voucher">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <t t-set="amount_text" t-value="(o.currency_id.amount_to_text(o.amount) or '').upper()"/>
                        <t t-if="amount_text.endswith(' PESO')" t-set="amount_text" t-value="amount_text[:-5] + ' PESOS'"/>
                        <t t-if="amount_text.endswith(' DOLAR')" t-set="amount_text" t-value="amount_text[:-6] + ' DOLARES'"/>
                        <t t-if="amount_text.endswith(' EURO')" t-set="amount_text" t-value="amount_text[:-5] + ' EUROS'"/>
                        <div class="row mb-3">
                            <div class="col-6"/>
                            <div class="col-6 text-end">
                                <span style="font-size: 34px; font-weight: 800;">RECIBO N&#186; <t t-esc="o.name"/></span><br/>
                                <span style="font-size: 18px; font-weight: 700;">
                                    <t t-if="o.move_type == 'income'">INGRESO DE CAJA</t>
                                    <t t-elif="o.move_type == 'expense'">GASTO DE CAJA</t>
                                    <t t-elif="o.move_type in ('transfer_in', 'transfer_out')">TRANSFERENCIA DE CAJA</t>
                                    <t t-else="">MOVIMIENTO DE CAJA</t>
                                    <t t-esc="' - %s' % o.box_id.name"/>
                                </span><br/>
                                <span style="font-size: 16px; font-weight: 700;"><t t-esc="o.date" t-options="{'widget': 'date'}"/></span>
                            </div>
                        </div>

                        <table style="width: 100%; font-size: 18px; border-collapse: collapse;">
                            <tr>
                                <td style="width: 22%; padding: 14px 0;">RECIB&#205; DE</td>
                                <td style="width: 78%; border-bottom: 1px solid #222; font-weight: 700; padding-left: 10px;">
                                    <t t-esc="(o.box_id.company_id.partner_id.name or o.company_id.name or '').upper()"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 14px 0;">LA SUMA DE</td>
                                <td style="background: #ececec; font-weight: 800; padding: 6px 10px;">
                                    <t t-esc="amount_text"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 14px 0;">RECIBO</td>
                                <td style="border-bottom: 1px solid #222; font-weight: 700; padding-left: 10px;">
                                    <t t-esc="(o.partner_id.name if o.partner_id else '').upper()"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 14px 0;">EN CONCEPTO DE</td>
                                <td style="border-bottom: 1px solid #222; font-weight: 700; padding-left: 10px;">
                                    <t t-esc="(o.description or '').upper()"/>
                                </td>
                            </tr>
                        </table>

                        <div class="row mt-5" style="font-size: 20px;">
                            <div class="col-5">
                                <span style="display: inline-block; width: 22%;">SON</span>
                                <span style="display: inline-block; width: 75%; background: #ececec; font-weight: 800; text-align: center;">
                                    <t t-esc="o.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                </span>
                            </div>
                            <div class="col-7 text-end" style="padding-top: 26px;">
                                <span style="display: inline-block; border-top: 1px dashed #333; min-width: 320px; text-align: center; padding-top: 8px; font-weight: 700;">
                                    FIRMA Y ACLARACI&#211;N
                                </span>
                            </div>
                        </div>

                        <div class="mt-3 text-muted" style="font-size: 12px;" t-if="o.account_move_id">
                            Asiento Contable: <t t-esc="o.account_move_id.name"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
