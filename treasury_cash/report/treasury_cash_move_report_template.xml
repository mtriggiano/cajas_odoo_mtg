<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="0">

    <template id="report_move_voucher">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="article" t-att-data-oe-model="o._name" t-att-data-oe-id="o.id" style="font-family: 'DejaVu Sans', 'Helvetica', sans-serif; font-size: 9px; line-height: 1.1; padding: 0;">
                        <style>@page { size: 148mm 105mm !important; margin: 2mm 3mm !important; }</style>
                        <t t-set="amount_text" t-value="(o.currency_id.amount_to_text(o.amount) or '').upper()"/>
                        <t t-if="amount_text.endswith(' PESO')" t-set="amount_text" t-value="amount_text[:-5] + ' PESOS'"/>
                        <t t-if="amount_text.endswith(' DOLAR')" t-set="amount_text" t-value="amount_text[:-6] + ' DOLARES'"/>
                        <t t-if="amount_text.endswith(' EURO')" t-set="amount_text" t-value="amount_text[:-5] + ' EUROS'"/>
                        <!-- Compact Header -->
                        <table style="width: 100%; margin-bottom: 3px;">
                            <tr>
                                <td style="width: 60%;"></td>
                                <td style="width: 40%; text-align: right; line-height: 1.1;">
                                    <div style="font-size: 13px; font-weight: 800;">RECIBO N&#186; <t t-esc="o.name"/></div>
                                    <div style="font-size: 8px; font-weight: 700;">
                                        <t t-if="o.move_type == 'income'">INGRESO</t>
                                        <t t-elif="o.move_type == 'expense'">GASTO</t>
                                        <t t-elif="o.move_type in ('transfer_in', 'transfer_out')">TRANSFERENCIA</t>
                                        <t t-else="">MOVIMIENTO</t>
                                        <t t-esc="' - %s' % o.box_id.name"/>
                                    </div>
                                    <div style="font-size: 8px; font-weight: 700;"><t t-esc="o.date" t-options="{'widget': 'date'}"/></div>
                                </td>
                            </tr>
                        </table>

                        <!-- Main data table - ultra compact -->
                        <table style="width: 100%; font-size: 8px; border-collapse: collapse; margin-bottom: 2px;">
                            <tr>
                                <td style="width: 16%; padding: 1px 0;">RECIB&#205; DE</td>
                                <td style="width: 84%; border-bottom: 1px solid #333; font-weight: 700; padding: 1px 3px;">
                                    <t t-esc="(o.box_id.company_id.partner_id.name or o.company_id.name or '').upper()"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 1px 0;">SUMA</td>
                                <td style="background: #e6e6e6; font-weight: 700; padding: 1px 3px;">
                                    <t t-esc="amount_text"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 1px 0;">RECIBO</td>
                                <td style="border-bottom: 1px solid #333; font-weight: 700; padding: 1px 3px;">
                                    <t t-esc="(o.partner_id.name if o.partner_id else '').upper()"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 1px 0;">CONCEPTO</td>
                                <td style="border-bottom: 1px solid #333; font-weight: 700; padding: 1px 3px;">
                                    <t t-esc="(o.description or '').upper()"/>
                                </td>
                            </tr>
                        </table>

                        <!-- Amount and Signature row -->
                        <table style="width: 100%; font-size: 8px; margin-top: 4px;">
                            <tr>
                                <td style="width: 30%; vertical-align: middle;">
                                    <span style="font-size: 7px;">SON:</span>
                                    <span style="background: #e6e6e6; font-weight: 700; padding: 1px 2px;">
                                        <t t-esc="o.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                    </span>
                                </td>
                                <td style="width: 70%; text-align: right; vertical-align: bottom; padding-top: 8px;">
                                    <span style="display: inline-block; border-top: 1px dashed #333; min-width: 110px; text-align: center; padding-top: 2px; font-weight: 700; font-size: 7px;">
                                        FIRMA Y ACLARACI&#211;N
                                    </span>
                                </td>
                            </tr>
                        </table>

                        <div style="margin-top: 2px; font-size: 7px; color: #555;" t-if="o.account_move_id">
                            Asiento: <t t-esc="o.account_move_id.name"/>
                        </div>
                    </div>
            </t>
        </t>
    </template>

</data>
</odoo>
