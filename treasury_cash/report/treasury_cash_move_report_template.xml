<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_move_voucher">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'DejaVu Sans', sans-serif; font-size: 11px; line-height: 1.2;">
                        <t t-set="amount_text" t-value="(o.currency_id.amount_to_text(o.amount) or '').upper()"/>
                        <t t-if="amount_text.endswith(' PESO')" t-set="amount_text" t-value="amount_text[:-5] + ' PESOS'"/>
                        <t t-if="amount_text.endswith(' DOLAR')" t-set="amount_text" t-value="amount_text[:-6] + ' DOLARES'"/>
                        <t t-if="amount_text.endswith(' EURO')" t-set="amount_text" t-value="amount_text[:-5] + ' EUROS'"/>
                        <div class="row" style="margin-bottom: 8px;">
                            <div class="col-6"/>
                            <div class="col-6 text-end">
                                <span style="font-size: 20px; font-weight: 800;">RECIBO N&#186; <t t-esc="o.name"/></span><br/>
                                <span style="font-size: 12px; font-weight: 700;">
                                    <t t-if="o.move_type == 'income'">INGRESO DE CAJA</t>
                                    <t t-elif="o.move_type == 'expense'">GASTO DE CAJA</t>
                                    <t t-elif="o.move_type in ('transfer_in', 'transfer_out')">TRANSFERENCIA DE CAJA</t>
                                    <t t-else="">MOVIMIENTO DE CAJA</t>
                                    <t t-esc="' - %s' % o.box_id.name"/>
                                </span><br/>
                                <span style="font-size: 11px; font-weight: 700;"><t t-esc="o.date" t-options="{'widget': 'date'}"/></span>
                            </div>
                        </div>

                        <table style="width: 100%; font-size: 11px; border-collapse: collapse;">
                            <tr>
                                <td style="width: 22%; padding: 6px 0;">RECIB&#205; DE</td>
                                <td style="width: 78%; border-bottom: 1px solid #222; font-weight: 700; padding-left: 8px;">
                                    <t t-esc="(o.box_id.company_id.partner_id.name or o.company_id.name or '').upper()"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 6px 0;">LA SUMA DE</td>
                                <td style="background: #ececec; font-weight: 800; padding: 4px 8px;">
                                    <t t-esc="amount_text"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 6px 0;">RECIBO</td>
                                <td style="border-bottom: 1px solid #222; font-weight: 700; padding-left: 8px;">
                                    <t t-esc="(o.partner_id.name if o.partner_id else '').upper()"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 6px 0;">EN CONCEPTO DE</td>
                                <td style="border-bottom: 1px solid #222; font-weight: 700; padding-left: 8px;">
                                    <t t-esc="(o.description or '').upper()"/>
                                </td>
                            </tr>
                        </table>

                        <div class="row" style="margin-top: 14px; font-size: 12px;">
                            <div class="col-5">
                                <span style="display: inline-block; width: 22%;">SON</span>
                                <span style="display: inline-block; width: 75%; background: #ececec; font-weight: 800; text-align: center; padding: 2px 4px;">
                                    <t t-esc="o.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                </span>
                            </div>
                            <div class="col-7 text-end" style="padding-top: 20px;">
                                <span style="display: inline-block; border-top: 1px dashed #333; min-width: 200px; text-align: center; padding-top: 6px; font-weight: 700; font-size: 11px;">
                                    FIRMA Y ACLARACI&#211;N
                                </span>
                            </div>
                        </div>

                        <div class="text-muted" style="margin-top: 6px; font-size: 9px;" t-if="o.account_move_id">
                            Asiento Contable: <t t-esc="o.account_move_id.name"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
