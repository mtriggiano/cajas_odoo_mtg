<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="seq_treasury_cash_session" model="ir.sequence">
        <field name="name">Sesión de Caja</field>
        <field name="code">treasury.cash.session</field>
        <field name="prefix">TCS/%(year)s/</field>
        <field name="padding">4</field>
    </record>

    <record id="seq_treasury_cash_move" model="ir.sequence">
        <field name="name">Movimiento de Caja</field>
        <field name="code">treasury.cash.move</field>
        <field name="prefix">TCM/%(year)s/</field>
        <field name="padding">5</field>
    </record>

    <record id="seq_treasury_cash_transfer" model="ir.sequence">
        <field name="name">Transferencia entre Cajas</field>
        <field name="code">treasury.cash.transfer</field>
        <field name="prefix">TCT/%(year)s/</field>
        <field name="padding">4</field>
    </record>

</odoo>
