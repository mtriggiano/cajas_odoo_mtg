<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Quickstart Wizard: Form View -->
    <!-- ============================================================ -->
    <record id="treasury_cash_quickstart_view_form" model="ir.ui.view">
        <field name="name">treasury.cash.quickstart.form</field>
        <field name="model">treasury.cash.quickstart</field>
        <field name="arch" type="xml">
            <form string="Configuración Rápida de Tesorería">
                <group>
                    <group string="Caja">
                        <field name="name"/>
                        <field name="code"/>
                        <field name="box_type"/>
                        <field name="responsible_user_id"/>
                        <field name="branch_id"/>
                    </group>
                    <group string="Empresa y Divisas">
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="currency_ids" widget="many2many_tags"/>
                    </group>
                </group>
                <group string="Configuración Automática de Cuentas">
                    <group>
                        <field name="create_accounts"/>
                    </group>
                </group>
                <group invisible="not create_accounts">
                    <group>
                        <field name="cash_account_prefix"/>
                        <field name="difference_account_code"/>
                        <field name="transfer_account_code"/>
                    </group>
                </group>
                <footer>
                    <button name="action_quickstart" type="object"
                            string="Crear Caja" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Quickstart Wizard: Action -->
    <!-- ============================================================ -->
    <record id="treasury_cash_quickstart_action" model="ir.actions.act_window">
        <field name="name">Asistente Rápido</field>
        <field name="res_model">treasury.cash.quickstart</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
